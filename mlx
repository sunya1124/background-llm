#!/bin/bash

# oMLX の起動・停止を管理するスクリプト

PLIST="$HOME/Library/LaunchAgents/jp.claude.omlx-server.plist"
MODEL_ID="Qwen3.6-35B-A3B-4bit"

# ポート8000が使用中かチェック
is_running() {
    lsof -i :8000 >/dev/null 2>&1
}

# 引数チェック
if [ "$1" = "-s" ]; then
    # 停止
    if is_running; then
        launchctl unload "$PLIST" 2>/dev/null
        echo "${MODEL_ID}のoMLXサーバーを停止したねり"
    else
        echo "${MODEL_ID}のoMLXサーバーは既に停止中ねり"
    fi
else
    # 起動（引数なし or それ以外の引数）
    if is_running; then
        echo "${MODEL_ID}のoMLXサーバーは既に起動中ねり"
    else
        launchctl bootout gui/$(id -u)/jp.claude.omlx-server 2>/dev/null
        launchctl bootstrap gui/$(id -u) "$PLIST"
        echo "${MODEL_ID}のoMLXサーバーを起動したねり"
        echo "http://localhost:8000"
    fi
fi
